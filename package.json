    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.7",
